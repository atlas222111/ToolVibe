# Backend Configuration (Copy to .env and update values)

# Secret key for JWT tokens (use long random string in production)
SECRET_KEY=your-super-secret-key-change-this-in-production-12345

# Database URL
DATABASE_URL=sqlite:///users.db

# Server
HOST=0.0.0.0
PORT=3001

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
DEBUG=True
